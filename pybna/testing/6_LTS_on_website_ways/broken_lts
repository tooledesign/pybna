CREATE TABLE "automated"."website_ways_through_pybna_for_lts_segment_break_forward" AS (
    SELECT
        "id",
        "geom",
        NULL::INTEGER AS lanes,
        NULL::BOOLEAN AS marked_centerline,
        NULL::INTEGER AS speed,
        NULL::INTEGER AS effective_aadt,
        NULL::BOOLEAN AS parking,
        NULL::INTEGER AS parking_width,
        NULL::INTEGER AS bike_lane_width,
        NULL::INTEGER AS stress
    FROM "automated"."website_pybna_lts_neighborhood_ways_break"
    WHERE FALSE
);

-----------------------------------------------
-- mixed traffic with all available data,
-- also bike lanes of substandard width
-- (uses tables in DB, based on Furth 2017 with
-- some adjustments)
-----------------------------------------------

-- #reading given and assumed road characteristics;
DROP TABLE IF EXISTS pg_temp.tmp_attrs;

-- two way
CREATE TEMP TABLE tmp_attrs AS (
    SELECT
        "id"::INTEGER AS id,
        COALESCE("ft_lanes", CASE  WHEN functional IN ('primary','secondary') THEN 2 WHEN functional IN ('tertiary') THEN 1 ELSE 1 END )::INTEGER AS lanes,
        COALESCE((NULL=NULL), CASE  WHEN functional IN ('primary','secondary','tertiary') THEN true ELSE false END )::BOOLEAN AS marked_centerline,
        COALESCE("speed_limi", CASE  WHEN functional IN ('primary','secondary') THEN 40 WHEN functional = 'tertiary' THEN 30 WHEN functional IN ('unclassified','residential') THEN 25 ELSE 30 END )::INTEGER AS speed,
        COALESCE(NULL, CASE  WHEN functional IN ('primary','secondary') THEN 20000 WHEN functional = 'tertiary' THEN 10000 WHEN functional IN ('unclassified','residential') THEN 500 ELSE 20000 END )::INTEGER AS effective_aadt
    FROM
        "automated"."website_pybna_lts_neighborhood_ways_break"
    WHERE
        ("ft_bike_in" IS NULL OR "ft_bike_in" NOT IN ('lane','buffered_lane','track','path'))
        AND TRUE
        AND ("one_way" IS NULL OR "one_way" NOT IN ('ft','tf'))
);

-- one way
INSERT INTO pg_temp.tmp_attrs
SELECT
    "id"::INTEGER,
    COALESCE("ft_lanes", CASE  WHEN functional IN ('primary','secondary') THEN 2 WHEN functional IN ('tertiary') THEN 1 ELSE 1 END )::INTEGER,
    TRUE::BOOLEAN,
    COALESCE("speed_limi", CASE  WHEN functional IN ('primary','secondary') THEN 40 WHEN functional = 'tertiary' THEN 30 WHEN functional IN ('unclassified','residential') THEN 25 ELSE 30 END )::INTEGER,
    (COALESCE(NULL, CASE  WHEN functional IN ('primary','secondary') THEN 20000 WHEN functional = 'tertiary' THEN 10000 WHEN functional IN ('unclassified','residential') THEN 500 ELSE 20000 END )*1.67)::INTEGER
FROM
    "automated"."website_pybna_lts_neighborhood_ways_break"
WHERE
    ("ft_bike_in" IS NULL OR "ft_bike_in" NOT IN ('lane','buffered_lane','track','path'))
    AND TRUE
    AND ("one_way"='ft')
;

CREATE INDEX tidx_tmp_attrs_id ON pg_temp.tmp_attrs (id); ANALYZE pg_temp.tmp_attrs;


-- #comparing against LTS tables;
DROP TABLE IF EXISTS pg_temp.tmp_stress;
CREATE TEMP TABLE pg_temp.tmp_stress AS (
    SELECT DISTINCT ON (tmp_attrs.id)
        tmp_attrs.id,
        lts.stress
    FROM
        pg_temp.tmp_attrs,
        "generated"."stress_shared" lts
    WHERE
        tmp_attrs.lanes <= lts.lanes
        AND tmp_attrs.marked_centerline = lts.marked_centerline
        AND tmp_attrs.speed <= lts.speed
        AND tmp_attrs.effective_aadt <= lts.effective_aadt
    ORDER BY
        tmp_attrs.id,
        lts.stress ASC
);

CREATE INDEX tidx_tmp_stress_id ON pg_temp.tmp_stress (id); ANALYZE pg_temp.tmp_stress;

INSERT INTO "automated"."website_ways_through_pybna_for_lts_segment_break_forward" (
    "id",
    "geom",
    lanes,
    marked_centerline,
    speed,
    effective_aadt,
    stress
)
SELECT
    tmp_attrs.id,
    "website_pybna_lts_neighborhood_ways_break".geom,
    tmp_attrs.lanes,
    tmp_attrs.marked_centerline,
    tmp_attrs.speed,
    tmp_attrs.effective_aadt,
    tmp_stress.stress
FROM
    pg_temp.tmp_attrs,
    "automated"."website_pybna_lts_neighborhood_ways_break",
    pg_temp.tmp_stress
WHERE
    tmp_attrs.id = "website_pybna_lts_neighborhood_ways_break"."id"
    AND tmp_attrs.id = tmp_stress.id
;

