-- #reading given and assumed road characteristics
DROP TABLE IF EXISTS pg_temp.tmp_attrs;
CREATE TEMP TABLE pg_temp.tmp_attrs AS (
    SELECT
        "id"::INTEGER AS id,
        COALESCE("ft_lanes", CASE  WHEN functional IN ('primary','secondary') THEN 2 WHEN functional IN ('tertiary') THEN 1 ELSE 1 END )::INTEGER AS lanes,
        ("one_way"='ft')::BOOLEAN AS oneway,
        COALESCE(("ft_park"=true), CASE  WHEN TRUE THEN true END )::BOOLEAN AS parking,
        COALESCE("ft_park_width", CASE  WHEN functional IN ('primary','secondary', 'tertiary') THEN 8 ELSE 0 END )::INTEGER AS parking_width,
        COALESCE("ft_bike_01", CASE  WHEN functional IN ('primary','secondary', 'tertiary') AND ft_bike_in = 'buffered_lane' THEN 6 WHEN functional IN ('primary','secondary', 'tertiary') AND tf_bike_in = 'buffered_lane' THEN 6 WHEN functional IN ('primary','secondary', 'tertiary') AND ft_bike_in = 'bike_lane' AND ft_park = TRUE THEN 5 WHEN functional IN ('primary','secondary', 'tertiary') AND ft_bike_in = 'bike_lane' AND ft_park = FALSE THEN 4 WHEN functional IN ('primary','secondary', 'tertiary') AND tf_bike_in = 'bike_lane' AND tf_park = TRUE THEN 5 WHEN functional IN ('primary','secondary', 'tertiary') AND tf_bike_in = 'bike_lane' AND tf_park = FALSE THEN 4 ELSE 5 END )::INTEGER AS bike_lane_width,
        COALESCE("speed_limi", CASE  WHEN functional IN ('primary','secondary') THEN 40 WHEN functional = 'tertiary' THEN 30 WHEN functional IN ('unclassified','residential') THEN 25 ELSE 30 END )::INTEGER AS speed
    FROM
        "automated"."website_pybna_lts_neighborhood_ways_break"
    WHERE
        ("ft_bike_in" IN ('lane','buffered_lane'))
        AND TRUE
);

CREATE INDEX tidx_tmp_attrs_id ON pg_temp.tmp_attrs (id); ANALYZE pg_temp.tmp_attrs;

-- #comparing against LTS tables;
DROP TABLE IF EXISTS pg_temp.tmp_stress;
CREATE TEMP TABLE pg_temp.tmp_stress AS (
    SELECT DISTINCT ON (tmp_attrs.id)
        tmp_attrs.id,
        lts.stress
    FROM
        pg_temp.tmp_attrs,
        "generated"."stress_bike_lane" lts
    WHERE
        tmp_attrs.lanes <= lts.lanes
        AND (lts.oneway IS NULL OR tmp_attrs.oneway = lts.oneway)
        AND tmp_attrs.parking = lts.parking
        AND (tmp_attrs.parking_width * tmp_attrs.parking::INTEGER) + tmp_attrs.bike_lane_width >= lts.reach
        AND tmp_attrs.speed <= lts.speed
    ORDER BY
        tmp_attrs.id,
        lts.stress ASC
);

CREATE INDEX tidx_tmp_stress_id ON pg_temp.tmp_stress (id); ANALYZE pg_temp.tmp_stress;

